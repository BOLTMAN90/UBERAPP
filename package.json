{
  "name": "uberapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "clean:cache": "node scripts/clean-metro-cache.mjs",
    "firebase:login": "firebase login",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage:rules --project bolexuber",
    "start": "node scripts/expo-start-lan.mjs",
    "start:clean": "node scripts/kill-metro-ports.mjs && node scripts/expo-start-lan.mjs -c",
    "dev": "node scripts/expo-start-lan.mjs",
    "dev:offline": "expo start --offline",
    "dev:clear": "node scripts/kill-metro-ports.mjs && node scripts/expo-start-lan.mjs -c",
    "dev:usb": "node scripts/expo-android-usb.mjs",
    "dev:usb:clear": "node scripts/expo-android-usb.mjs -c",
    "dev:firewall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-allow-expo-metro.ps1",
    "dev:clear:offline": "expo start -c --offline",
    "dev:tunnel": "expo start --tunnel -c",
    "web": "node scripts/start-expo-web.mjs",
    "tunnel": "expo start --tunnel",
    "dev:emulators": "concurrently -k \"npm run emulators\" \"npm run dev:emulators:app\"",
    "dev:emulators:app": "wait-on tcp:127.0.0.1:9099 tcp:127.0.0.1:8080 && node scripts/seed-emulators.mjs && node scripts/start-expo-emulator-mode.mjs",
    "emulators": "node scripts/start-emulators.mjs",
    "seed": "node scripts/seed-emulators.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "maps:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/maps-setup.ps1",
    "update:preview": "eas update --channel preview --environment preview --non-interactive",
    "update:production": "eas update --channel production --environment production --non-interactive"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.10",
    "concurrently": "^9.2.1",
    "firebase-tools": "^14.22.0",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.3"
  },
  "private": true
}
