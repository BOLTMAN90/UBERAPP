{
  "expo": {
    "name": "BoltRide",
    "slug": "uberapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uberapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/boltride-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.student.rideyellow",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BoltRide uses your location to show pickup points and match nearby drivers.",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "package": "com.student.rideyellow",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow BoltRide to use your location for pickups and live ride tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00AEEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY",
      "router": {},
      "eas": {
        "projectId": "2a118d94-c801-479b-b4ee-b987b6b9f6b6"
      }
    },
    "owner": "bolex"
  }
}
