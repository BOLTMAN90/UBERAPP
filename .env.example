# Copy to ".env" in the project root (same folder as package.json).
# Expo loads EXPO_PUBLIC_* at build time — restart the dev server after changes.

# Optional: if Expo Go still cannot connect on LAN, set your PC's IPv4 from ipconfig (e.g. 192.168.1.42).
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.42

# No spaces around = and no quotes around values (wrong: KEY= "abc", right: KEY=abc)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Maps API key (used when native Google Maps is enabled below).
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Release APK uses OpenStreetMap by default (map works without SHA-1 setup).
# After adding EAS keystore SHA-1 in Google Cloud (npm run maps:setup), set:
# EXPO_PUBLIC_USE_GOOGLE_MAPS_NATIVE=true
# Then: eas env:push --environment preview --path .env && eas build -p android --profile preview

# Optional: local Firebase emulators (requires Java). Use with: npm run dev:emulators
# EXPO_PUBLIC_USE_FIREBASE_EMULATORS=true
